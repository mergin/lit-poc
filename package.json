    "./ssr": {
      "import": "./dist/ssr.js",
      "types": "./dist/ssr/index.d.ts"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "vite build --config vite.lib.config.ts && tsc --project tsconfig.build.json --emitDeclarationOnly",
    "build:tokens": "style-dictionary build --config src/styles/sd.config.mjs",
    "build:watch": "tsc --noEmit --watch",
    "clean": "rm -rf dist/ test-results/ docs/ node_modules/",
    "rebuild": "npm run clean && npm i && npm run build",
    "lint": "npm run lint:lit-analyzer && npm run lint:eslint",
    "lint:eslint": "eslint \"src/**/*.ts\"",
    "lint:lit-analyzer": "lit-analyzer",
    "format": "prettier \"**/*.{cjs,html,js,json,md,ts}\" --ignore-path ./.eslintignore --write",
    "docs": "npm run docs:clean && npm run build && npm run analyze && npm run docs:build && npm run docs:assets && npm run docs:gen",
    "docs:clean": "rimraf docs",
    "docs:gen": "eleventy --config=.eleventy.cjs",
    "docs:gen:watch": "eleventy --config=.eleventy.cjs --watch",
    "docs:build": "vite build --config vite.docs.config.ts",
    "docs:assets": "cp node_modules/prismjs/themes/prism-okaidia.css docs/",
    "docs:serve": "vite --root docs",
    "analyze": "cem analyze --litelement --globs \"src/**/*.ts\"",
    "analyze:watch": "cem analyze --litelement --globs \"src/**/*.ts\" --watch",
    "serve": "vite",
    "serve:prod": "vite preview",
    "test": "npm run test:unit",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:perf": "vitest bench --environment happy-dom",
    "test:e2e": "playwright test",
    "test:e2e:log": "bash scripts/e2e-log.sh",
    "test:e2e:install": "playwright install webkit chromium firefox",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test --project=visual",
    "test:visual:update": "playwright test --project=visual --update-snapshots",
    "checksize": "vite build --config vite.docs.config.ts && cat docs/mu-button.bundled.js | gzip -9 | wc -c",
    "prepare": "husky install",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN"
  },
  "keywords": [
    "web-components",
    "lit-element",
    "typescript",
    "lit"
  ],
  "author": "David Prieto",
  "license": "BSD-3-Clause",
  "peerDependencies": {
    "@angular/core": ">=14.0.0",
    "@angular/forms": ">=14.0.0",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0",
    "svelte": ">=5.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "@angular/forms": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "dependencies": {
    "@lit-labs/ssr": "^4.0.0",
    "@lit/context": "^1.1.6",
    "@lit/react": "^1.0.8",
    "lit": "^3.3.2"
  },
