{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/_tests/**",
    "src/**/*.stories.ts",
    "src/test/**",
    "src/stories/**",
    "src/internal/utils/a11y.ts"
  ]
}
