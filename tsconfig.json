{
  "compilerOptions": {
    "useDefineForClassFields": false,
    "target": "es2021",
    "module": "es2020",
    "lib": ["es2021", "DOM", "DOM.Iterable"],
    // "declaration": true,
    // "declarationMap": true,
    "sourceMap": true,
    "inlineSources": true,
    // "outDir": "./src", // removed for Rollup compatibility
    "noEmit": true,
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitOverride": true,
    "plugins": [
      {
        "name": "ts-lit-plugin",
        "strict": true
      }
    ],
    "types": ["node", "svelte"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/_tests/*.test.ts"]
}
